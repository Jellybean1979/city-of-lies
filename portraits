      btn.classList.add('active');

      let count = 0;
      document.querySelectorAll('.portrait-card').forEach(card => {
        const match = role === 'all' || card.dataset.role === role;
        card.classList.toggle('hidden', !match);
        if (match) count++;
      });
      document.getElementById('showing-count').textContent = count;
    }

