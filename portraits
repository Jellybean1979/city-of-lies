    (function resumeMusic() {
      try {
        const saved = JSON.parse(sessionStorage.getItem('col_music') || '{}');
        musicEnabled = saved.enabled !== false;
        if (!musicEnabled) return;
        if (saved.time)   music.currentTime = saved.time;
        music.volume = saved.volume ?? 0.42;
        music.play().catch(() => {
          const unlock = () => {
            music.play().catch(() => {});
            document.removeEventListener('click',      unlock);
            document.removeEventListener('touchstart', unlock);
          };
          document.addEventListener('click',      unlock, { passive: true });
          document.addEventListener('touchstart', unlock, { passive: true });
        });
      } catch(e) {}
    })();

    function saveMusicState() {
      sessionStorage.setItem('col_music', JSON.stringify({
        enabled: musicEnabled,
        time:    music.currentTime,
        volume:  music.volume,
        src:     'Assets/Audio/Background music/Echoes_in_the_Concrete_Maze.mp3'
      }));
