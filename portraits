        if (!res.ok) throw new Error();
        const data = await res.json();
        const sha  = data[0]?.sha?.substring(0, 7) ?? '-------';
        document.getElementById('versionTag').textContent = `v0.1.0 · ${sha}`;
      } catch {
        document.getElementById('versionTag').textContent = 'v0.1.0 · local';
      }
    }
