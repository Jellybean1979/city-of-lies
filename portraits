      document.getElementById('dossier-notes-field').value = savedNote;
      document.getElementById('notes-saved-indicator').classList.remove('show');

      // Open
      document.getElementById('dossier-overlay').classList.add('open');
      document.getElementById('dossier').scrollTop = 0;
      document.body.style.overflow = 'hidden';
    }

